# Normalize all text files to LF in the repo so the Docker (Linux) build
# doesn't choke on CRLF endings. Windows checkouts still get CRLF locally.
* text=auto eol=lf

# Explicit overrides
*.py    text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
Dockerfile text eol=lf
