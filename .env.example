# Copy this file to .env and fill in real values. .env is gitignored.
# For Render deploys, set these in the Render dashboard's Environment tab
# (NOT in .env) so they don't end up in git.

# Required for real handwriting OCR. Get a key from console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-haiku-4-5 (~$0.003/page).
# Other options: claude-sonnet-4-6, claude-opus-4-7 (sharper but more expensive).
# ANTHROPIC_VISION_MODEL=claude-haiku-4-5

# Optional. Render sets PORT automatically; defaults to 8000 locally.
# PORT=8000
